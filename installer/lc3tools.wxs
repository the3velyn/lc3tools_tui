<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="LC-3 Tools"
           Manufacturer="Doug Townsend"
           Version="0.1.0"
           UpgradeCode="e62a7b3c-8f1d-4c6a-9d2e-5f4a3b1c0d9e">

    <MajorUpgrade DowngradeErrorMessage="A newer version of LC-3 Tools is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="LC-3 Tools" Level="1">
      <ComponentGroupRef Id="ExeFiles" />
      <ComponentRef Id="PathEntry" />
    </Feature>
  </Package>

  <!-- Install directory -->
  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="lc3tools" />
    </StandardDirectory>
  </Fragment>

  <!-- Add install directory to system PATH -->
  <Fragment>
    <Component Id="PathEntry" Directory="INSTALLFOLDER" Guid="a1b2c3d4-e5f6-7890-abcd-ef1234567890">
      <Environment Id="PATH"
                   Name="PATH"
                   Value="[INSTALLFOLDER]"
                   Permanent="no"
                   Part="last"
                   Action="set"
                   System="yes" />
    </Component>
  </Fragment>

  <!-- Executable files -->
  <Fragment>
    <ComponentGroup Id="ExeFiles" Directory="INSTALLFOLDER">
      <Component Guid="b2c3d4e5-f6a7-8901-bcde-f12345678901">
        <File Source="dist\lc3asm\lc3asm.exe" />
      </Component>
      <Component Guid="c3d4e5f6-a7b8-9012-cdef-123456789012">
        <File Source="dist\lc3sim\lc3sim.exe" />
      </Component>
      <Component Guid="d4e5f6a7-b8c9-0123-defa-234567890123">
        <File Source="dist\lc3pysim\lc3pysim.exe" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
